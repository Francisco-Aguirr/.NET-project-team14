@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "SuperAdmin")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using BookingSystem.Web.Data

@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager

<h3>Admin Dashboard</h3>

<hr />

<h4>Applications from entrepreneurs</h4>

@if (requests == null)
{
    <p><em>Loading...</em></p>
}
else if (!requests.Any())
{
    <p>There are no pending requests.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var req in requests)
            {
                <tr>
                    <td>@req.UserEmail</td>
                    <td>@req.RequestedAt.ToLocalTime()</td>
                    <td>
                        <button class="btn btn-success btn-sm" @onclick="() => Approve(req)">Aprove</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => Reject(req)">Reject</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h4>Business Categories</h4>

<input class="form-control mb-2" placeholder="Nueva categoría" @bind="newCategory" />
<button class="btn btn-primary mb-3" @onclick="AddCategory">Add</button>

@if (categories == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in categories)
            {
                <tr>
                    <td>@cat.Name</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteCategory(cat.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<RequestViewModel> requests = new();
    private List<BusinessCategory> categories = new();
    private string newCategory = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // Cargar solicitudes
        var dbRequests = await DbContext.EntrepreneurRequests
            .Where(r => !r.IsApproved)
            .ToListAsync();

        requests = new List<RequestViewModel>();

        foreach (var req in dbRequests)
        {
            var user = await UserManager.FindByIdAsync(req.UserId);

            if (user != null)
            {
                requests.Add(new RequestViewModel
                {
                    Id = req.Id,
                    UserId = user.Id,
                    UserEmail = user.Email!,
                    RequestedAt = req.RequestedAt
                });
            }
        }

        // Cargar categorías
        categories = await DbContext.BusinessCategories.ToListAsync();
    }

    private async Task Approve(RequestViewModel req)
    {
        var dbReq = await DbContext.EntrepreneurRequests.FindAsync(req.Id);

        if (dbReq != null)
        {
            dbReq.IsApproved = true;

            var user = await UserManager.FindByIdAsync(req.UserId);

            if (user != null)
            {
                await UserManager.AddToRoleAsync(user, "Entrepreneur");
            }

            await DbContext.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task Reject(RequestViewModel req)
    {
        var dbReq = await DbContext.EntrepreneurRequests.FindAsync(req.Id);

        if (dbReq != null)
        {
            DbContext.EntrepreneurRequests.Remove(dbReq);
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task AddCategory()
    {
        if (!string.IsNullOrWhiteSpace(newCategory))
        {
            var cat = new BusinessCategory { Name = newCategory };
            DbContext.BusinessCategories.Add(cat);

            await DbContext.SaveChangesAsync();

            newCategory = "";
            await LoadData();
        }
    }

    private async Task DeleteCategory(int id)
    {
        var cat = await DbContext.BusinessCategories.FindAsync(id);

        if (cat != null)
        {
            DbContext.BusinessCategories.Remove(cat);
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
    }

    private class RequestViewModel
    {
        public int Id { get; set; }
        public string UserId { get; set; } = "";
        public string UserEmail { get; set; } = "";
        public DateTime RequestedAt { get; set; }
    }
}